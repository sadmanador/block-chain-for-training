# Blockchain & Non-Blockchain Multi-Project Gitignore
# This file handles ignoring artifacts from both subdirectories recursively.

# dependencies
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/
dist/

# misc
.DS_Store
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (covers .env, .env.local, .env.production, etc. in all folders)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Blockchain specific data (if needed to ignore persistent storage in dev)
# blockchain/data/*.json
# blockchain/wallet/
